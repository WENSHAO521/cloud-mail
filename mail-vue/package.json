{
  "name": "psg-mail",
  "description": "PSG Mail — Panorama Scholarly Group institutional email client",
  "author": "Panorama Scholarly Group <admin@panorama-sg.com>",
  "homepage": "https://panorama-sg.com",
  "private": true,
  "version": "2.4.5",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --mode dev",
    "remote": "vite --mode remote",
    "build": "vite build --mode release",
    "eo": "vite build --mode eo",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development node electron/launcher.cjs",
    "generate:icons": "node scripts/generate-psg-app-icons.cjs",
    "build:android": "vite build --mode android && node scripts/generate-psg-app-icons.cjs",
    "android:sync": "npm run build:android && npx cap sync android",
    "android:apk": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:apk:release": "npm run android:sync && cd android && gradlew.bat assembleRelease",
    "electron:build": "vite build --mode electron && node scripts/generate-psg-app-icons.cjs && electron-builder",
    "build:native": "npm run generate:icons && npm run electron:build && npm run android:apk"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@iconify/vue": "^4.3.0",
    "@vueuse/components": "^14.1.0",
    "@vueuse/core": "^12.0.0",
    "axios": "1.15.2",
    "compressorjs": "^1.2.1",
    "date-time-format-timezone": "^1.0.22",
    "dayjs": "^1.11.13",
    "dexie": "^4.0.11",
    "echarts": "^5.6.0",
    "electron-updater": "^6.8.9",
    "element-plus": "^2.13.1",
    "lodash-es": "^4.17.21",
    "nprogress": "^0.2.0",
    "path": "^0.12.7",
    "pinia": "^3.0.2",
    "pinia-plugin-persistedstate": "^4.2.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.10",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@resvg/resvg-js": "^2.6.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "cross-env": "^7.0.3",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "less": "^4.2.2",
    "sass": "^1.82.0",
    "terser": "^5.39.0",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-vue-components": "^28.7.0",
    "vite": "7.1.5",
    "vite-plugin-pwa": "^1.0.3"
  }
}
